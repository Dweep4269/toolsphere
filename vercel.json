{
  "crons": [
    {
      "path": "/api/cron/daily-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "functions": {
    "src/app/api/integrations/*/sync/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/enrich-descriptions/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/daily-sync/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/search/nlp/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/admin/sync/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/admin/llm-batch/route.ts": {
      "maxDuration": 60
    }
  }
}
